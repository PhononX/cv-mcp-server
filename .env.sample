CARBON_VOICE_API_KEY=SUPER_SECRET # Only stdio uses it
CARBON_VOICE_BASE_URL=https://api.carbonvoice.app
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_TRANSPORT=file
# Set to false when running the stateless transport (start:http:stateless / dev:http:stateless).
# The stateless npm scripts set this automatically — only override here if needed.
# MCP_SESSION_LOGS_ENABLED=true